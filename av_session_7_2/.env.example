# Copy to .env and fill in real values:  cp .env.example .env
# Hostnames "db" and "cache" are the docker-compose service names.

# --- Postgres (db service) ---
POSTGRES_USER=ordertrack
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ordertrack

# --- Backend (api service) ---
# Must point at the "db" / "cache" service names, not localhost.
DATABASE_URL=postgresql://ordertrack:change-me@db:5432/ordertrack
REDIS_URL=redis://cache:6379/0
# Strong random string in production: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret
ORDER_STATUS_CACHE_TTL=30

# --- Host port mappings ---
API_PORT=8010
FRONTEND_PORT=8080
