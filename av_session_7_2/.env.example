# OrderTrack environment template. Copy to .env and fill in real values.
#   cp .env.example .env
# Hostnames "db" and "cache" are the docker-compose service names.

# --- Postgres (db service) ---
POSTGRES_USER=ordertrack
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ordertrack

# --- Backend (api service) ---
# Must match the Postgres creds above; host is the "db" service.
DATABASE_URL=postgresql://ordertrack:change-me-strong-password@db:5432/ordertrack
REDIS_URL=redis://cache:6379/0
# Random 32+ char secret used to sign JWTs. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-random-secret
ORDER_STATUS_CACHE_TTL=30

# --- Host port mappings ---
API_PORT=8010
FRONTEND_PORT=8080
