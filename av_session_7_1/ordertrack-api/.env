# OrderTrack API environment — REAL credentials (this file should never be committed)
FLASK_ENV=production
SECRET_KEY=dev-secret-hardcoded
API_KEY=sk-test-abc123xyz

DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=localhost
# Postgres runs on 5433 in this project (docker-compose db: command -p 5433,
# published as 5433:5433), not the default 5432.
DB_PORT=5433
DB_NAME=ordertrack

# psycopg2 (order_service.get_orders) reads these for auth.
PGUSER=postgres
PGPASSWORD=postgres123

REDIS_HOST=localhost
REDIS_PORT=6379
